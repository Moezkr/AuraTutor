)\n","    false_alarms = [t for t in alarm_indices if t < drift_start_index]\n","    true_alarms = [t for t in alarm_indices if t >= drift_start_index]\n","\n","    # 2. Calcul du False Alert Rate (FAR) en pourcentage\n","    # C'est le nombre de fausses alarmes divisé par le nombre d'interactions \"saines\"\n","    far_percentage = (len(false_alarms) / drift_start_index) * 100\n","\n","    # 3. Calcul du Detection Delay (Délai de détection)\n","    if len(true_alarms) > 0:\n","        first_valid_alarm = true_alarms[0]\n","        detection_delay = first_valid_alarm - drift_start_index\n","    else:\n","        detection_delay = \"N/A (Non détecté)\"\n","\n","    return detection_delay, far_percentage\n","\n","# ==========================================\n","# EXEMPLE D'UTILISATION DANS VOTRE CODE :\n","# ==========================================\n","# Imaginons que votre Testing Block fait 50 000 interactions.\n","# Vous avez injecté la dérive à l'interaction 25 000.\n","\n","drift_injection_t = 25000\n","total_t = 50000\n","\n","# 1. Obtenez les chiffres pour ADWIN seul\n","adwin_alarms = [1200, 18500, 25012, 31000] # Vos vrais logs ADWIN\n","delay_adwin, far_adwin = calculate_ablation_metrics(adwin_alarms, drift_injection_t, total_t)\n","print(f\"ADWIN -> Delay: {delay_adwin} interactions, FAR: {far_adwin:.2f}%\")\n","\n","# 2. Obtenez les chiffres pour KSWIN seul\n","kswin_alarms = [500, 3000, 8000, 14000, 21000, 24000, 25003, 26000] # Vos vrais logs KSWIN\n","delay_kswin, far_kswin = calculate_ablation_metrics(kswin_alarms, drift_injection_t, total_t)\n","print(f\"KSWIN -> Delay: {delay_kswin} interactions, FAR: {far_kswin:.2f}%\")\n","\n","# 3. Obtenez les chiffres pour le système complet (Porte AND : les deux capteurs sonnent en même temps)\n","and_alarms = [25005, 31005] # Vos vrais logs xGATES\n","delay_xgates, far_xgates = calculate_ablation_metrics(and_alarms, drift_injection_t, total_t)\n","print(f\"xGATES -> Delay: {delay_xgates} interactions, FAR: {far_xgates:.2f}%\")"],"metadata":{"id":"tuAle3bS8YrL","executionInfo":{"status":"ok","timestamp":1775390765464,"user_tz":-60,"elapsed":88,"user":{"displayName":"Oumaima Méchi","userId":"09875582261966675902"}},"outputId":"bd96f35e-b05e-458a-bc5a-28e9014badb2","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":20,"outputs":[{"output_type":"stream","name":"stdout","text":["ADWIN -> Delay: 12 interactions, FAR: 0.01%\n","KSWIN -> Delay: 3 interactions, FAR: 0.02%\n","xGATES -> Delay: 5 interactions, FAR: 0.00%\n"]}]}]}